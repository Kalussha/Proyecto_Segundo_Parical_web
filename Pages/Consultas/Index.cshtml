@page
@model Proyecto_Segundo_Parcial.Pages.Consultas.IndexModel
@{
    ViewData["Title"] = "Gestión de Consultas";
}

<div class="container-fluid py-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h2 fw-bold text-info">
                <i class="fas fa-comments me-2"></i>Gestión de Consultas y Actualizaciones
            </h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-page="Create" class="btn btn-info btn-lg shadow-sm">
                <i class="fas fa-plus me-2"></i>Nueva Consulta
            </a>
        </div>
    </div>

    @if (Model.Consultas.Count == 0)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="fas fa-info-circle me-2"></i>
            No hay consultas registradas.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th><i class="fas fa-heading me-2"></i>Asunto</th>
                        <th><i class="fas fa-user me-2"></i>Empleado</th>
                        <th><i class="fas fa-tag me-2"></i>Tipo</th>
                        <th><i class="fas fa-info-circle me-2"></i>Estado</th>
                        <th><i class="fas fa-calendar me-2"></i>Fecha</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var consulta in Model.Consultas)
                    {
                        <tr class="align-middle">
                            <td class="fw-semibold">@consulta.Asunto</td>
                            <td>
                                <small>@consulta.Empleado?.Nombre @consulta.Empleado?.Apellido</small>
                            </td>
                            <td>
                                @switch (consulta.Tipo)
                                {
                                    case ProyectoSegundoParcial.Models.TipoConsulta.Alias:
                                        <span class="badge bg-secondary">Alias</span>
                                        break;
                                    case ProyectoSegundoParcial.Models.TipoConsulta.Consulta:
                                        <span class="badge bg-primary">Consulta</span>
                                        break;
                                    case ProyectoSegundoParcial.Models.TipoConsulta.Actualizacion:
                                        <span class="badge bg-warning text-dark">Actualización</span>
                                        break;
                                    case ProyectoSegundoParcial.Models.TipoConsulta.Otro:
                                        <span class="badge bg-secondary">Otro</span>
                                        break;
                                }
                            </td>
                            <td>
                                @switch (consulta.Estado)
                                {
                                    case ProyectoSegundoParcial.Models.EstadoConsulta.Pendiente:
                                        <span class="badge bg-danger">Pendiente</span>
                                        break;
                                    case ProyectoSegundoParcial.Models.EstadoConsulta.EnProceso:
                                        <span class="badge bg-warning text-dark">En Proceso</span>
                                        break;
                                    case ProyectoSegundoParcial.Models.EstadoConsulta.Resuelta:
                                        <span class="badge bg-success">Resuelta</span>
                                        break;
                                    case ProyectoSegundoParcial.Models.EstadoConsulta.Cerrada:
                                        <span class="badge bg-secondary">Cerrada</span>
                                        break;
                                }
                            </td>
                            <td>
                                <small>@consulta.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</small>
                            </td>
                            <td class="text-center">
                                <a asp-page="Details" asp-route-id="@consulta.Id" class="btn btn-sm btn-info" title="Ver">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-page="Edit" asp-route-id="@consulta.Id" class="btn btn-sm btn-warning" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-page="Delete" asp-route-id="@consulta.Id" class="btn btn-sm btn-danger" title="Eliminar">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .table-hover tbody tr {
        transition: background-color 0.2s ease;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(23, 162, 184, 0.05);
    }
</style>
