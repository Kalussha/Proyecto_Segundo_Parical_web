@page
@model Proyecto_Segundo_Parcial.Pages.Consultas.CreateModel
@{
    ViewData["Title"] = "Crear Consulta";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-info text-white py-4">
                    <h2 class="mb-0">
                        <i class="fas fa-comment-circle-plus me-2"></i>Nueva Consulta o Actualizaciˇn
                    </h2>
                </div>

                <div class="card-body p-5">
                    <form method="post" novalidate>
                        <div class="mb-3">
                            <label asp-for="Consulta.EmpleadoId" class="form-label fw-semibold">
                                <i class="fas fa-user me-2 text-info"></i>Empleado
                            </label>
                            <select asp-for="Consulta.EmpleadoId" asp-items="@(new SelectList(Model.Empleados, "Id", "Nombre"))" 
                                class="form-select form-select-lg" required>
                            </select>
                            <span asp-validation-for="Consulta.EmpleadoId" class="invalid-feedback d-block"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Consulta.Tipo" class="form-label fw-semibold">
                                    <i class="fas fa-tag me-2 text-info"></i>Tipo de Consulta
                                </label>
                                <select asp-for="Consulta.Tipo" asp-items="Html.GetEnumSelectList<ProyectoSegundoParcial.Models.TipoConsulta>()" 
                                    class="form-select form-select-lg" required>
                                    <option value="">-- Seleccionar Tipo --</option>
                                </select>
                                <span asp-validation-for="Consulta.Tipo" class="invalid-feedback d-block"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Consulta.Estado" class="form-label fw-semibold">
                                    <i class="fas fa-circle-info me-2 text-info"></i>Estado
                                </label>
                                <select asp-for="Consulta.Estado" asp-items="Html.GetEnumSelectList<ProyectoSegundoParcial.Models.EstadoConsulta>()" 
                                    class="form-select form-select-lg" required>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Consulta.Asunto" class="form-label fw-semibold">
                                <i class="fas fa-heading me-2 text-info"></i>Asunto
                            </label>
                            <input asp-for="Consulta.Asunto" class="form-control form-control-lg" 
                                placeholder="Ingrese el asunto" required />
                            <span asp-validation-for="Consulta.Asunto" class="invalid-feedback d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Consulta.Descripcion" class="form-label fw-semibold">
                                <i class="fas fa-align-left me-2 text-info"></i>Descripciˇn
                            </label>
                            <textarea asp-for="Consulta.Descripcion" class="form-control form-control-lg" 
                                rows="5" placeholder="Describa la consulta o actualizaciˇn..."></textarea>
                            <span asp-validation-for="Consulta.Descripcion" class="invalid-feedback d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Consulta.Respuesta" class="form-label fw-semibold">
                                <i class="fas fa-reply me-2 text-info"></i>Respuesta (Opcional)
                            </label>
                            <textarea asp-for="Consulta.Respuesta" class="form-control form-control-lg" 
                                rows="3" placeholder="Respuesta a la consulta..."></textarea>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
                            <a asp-page="Index" class="btn btn-lg btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-lg btn-info">
                                <i class="fas fa-save me-2"></i>Registrar Consulta
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
