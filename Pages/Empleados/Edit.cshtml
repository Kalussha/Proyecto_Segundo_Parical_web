@page "{id}"
@model Proyecto_Segundo_Parcial.Pages.Empleados.EditModel
@{
    ViewData["Title"] = "Editar Empleado";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-warning text-dark py-4">
                    <h2 class="mb-0">
                        <i class="fas fa-user-edit me-2"></i>Editar Empleado
                    </h2>
                </div>

                <div class="card-body p-5">
                    <form method="post" novalidate>
                        <input type="hidden" asp-for="Empleado.Id" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Empleado.Nombre" class="form-label fw-semibold">
                                    <i class="fas fa-user me-2 text-warning"></i>Nombre
                                </label>
                                <input asp-for="Empleado.Nombre" class="form-control form-control-lg" />
                                <span asp-validation-for="Empleado.Nombre" class="invalid-feedback"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Empleado.Apellido" class="form-label fw-semibold">
                                    <i class="fas fa-user me-2 text-warning"></i>Apellido
                                </label>
                                <input asp-for="Empleado.Apellido" class="form-control form-control-lg" />
                                <span asp-validation-for="Empleado.Apellido" class="invalid-feedback"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Empleado.Email" class="form-label fw-semibold">
                                    <i class="fas fa-envelope me-2 text-warning"></i>Email
                                </label>
                                <input asp-for="Empleado.Email" type="email" class="form-control form-control-lg" />
                                <span asp-validation-for="Empleado.Email" class="invalid-feedback"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Empleado.Telefono" class="form-label fw-semibold">
                                    <i class="fas fa-phone me-2 text-warning"></i>Teléfono
                                </label>
                                <input asp-for="Empleado.Telefono" type="tel" class="form-control form-control-lg" />
                                <span asp-validation-for="Empleado.Telefono" class="invalid-feedback"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Empleado.Cargo" class="form-label fw-semibold">
                                    <i class="fas fa-briefcase me-2 text-warning"></i>Cargo
                                </label>
                                <input asp-for="Empleado.Cargo" class="form-control form-control-lg" />
                                <span asp-validation-for="Empleado.Cargo" class="invalid-feedback"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Empleado.DepartamentoId" class="form-label fw-semibold">
                                    <i class="fas fa-building me-2 text-warning"></i>Departamento
                                </label>
                                <select asp-for="Empleado.DepartamentoId" asp-items="@(new SelectList(Model.Departamentos, "Id", "Nombre"))" 
                                    class="form-select form-select-lg"></select>
                                <span asp-validation-for="Empleado.DepartamentoId" class="invalid-feedback"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Empleado.FechaIngreso" class="form-label fw-semibold">
                                    <i class="fas fa-calendar me-2 text-warning"></i>Fecha de Ingreso
                                </label>
                                <input asp-for="Empleado.FechaIngreso" type="date" class="form-control form-control-lg" />
                                <span asp-validation-for="Empleado.FechaIngreso" class="invalid-feedback"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Empleado.Salario" class="form-label fw-semibold">
                                    <i class="fas fa-dollar-sign me-2 text-warning"></i>Salario
                                </label>
                                <input asp-for="Empleado.Salario" type="number" step="0.01" class="form-control form-control-lg" />
                                <span asp-validation-for="Empleado.Salario" class="invalid-feedback"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Empleado.Estado" class="form-label fw-semibold">
                                <i class="fas fa-badge me-2 text-warning"></i>Estado
                            </label>
                            <select asp-for="Empleado.Estado" asp-items="Html.GetEnumSelectList<ProyectoSegundoParcial.Models.EstadoEmpleado>()" 
                                class="form-select form-select-lg"></select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Empleado.Observaciones" class="form-label fw-semibold">
                                <i class="fas fa-sticky-note me-2 text-warning"></i>Observaciones
                            </label>
                            <textarea asp-for="Empleado.Observaciones" class="form-control form-control-lg" rows="3"></textarea>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
                            <a asp-page="Index" class="btn btn-lg btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-lg btn-warning text-dark">
                                <i class="fas fa-save me-2"></i>Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
