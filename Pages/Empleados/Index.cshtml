@page
@model Proyecto_Segundo_Parcial.Pages.Empleados.IndexModel
@{
    ViewData["Title"] = "Gestión de Empleados";
}

<div class="container-fluid py-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h2 fw-bold text-primary">
                <i class="fas fa-users me-2"></i>Gestión de Empleados
            </h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-page="Create" class="btn btn-primary btn-lg shadow-sm">
                <i class="fas fa-plus me-2"></i>Nuevo Empleado
            </a>
        </div>
    </div>

    @if (Model.Empleados.Count == 0)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="fas fa-info-circle me-2"></i>
            No hay empleados registrados. <a asp-page="Create">Crear uno ahora</a>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th><i class="fas fa-id-card me-2"></i>Empleado</th>
                        <th><i class="fas fa-envelope me-2"></i>Email</th>
                        <th><i class="fas fa-phone me-2"></i>Teléfono</th>
                        <th><i class="fas fa-briefcase me-2"></i>Cargo</th>
                        <th><i class="fas fa-building me-2"></i>Departamento</th>
                        <th><i class="fas fa-calendar me-2"></i>Ingreso</th>
                        <th><i class="fas fa-badge me-2"></i>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var empleado in Model.Empleados)
                    {
                        <tr class="align-middle">
                            <td class="fw-semibold">
                                @empleado.Nombre @empleado.Apellido
                            </td>
                            <td>
                                <small class="text-muted">@empleado.Email</small>
                            </td>
                            <td>
                                <small>@empleado.Telefono</small>
                            </td>
                            <td>
                                <small>@empleado.Cargo</small>
                            </td>
                            <td>
                                <span class="badge bg-info text-dark">
                                    @empleado.Departamento?.Nombre
                                </span>
                            </td>
                            <td>
                                <small>@empleado.FechaIngreso.ToString("dd/MM/yyyy")</small>
                            </td>
                            <td>
                                @switch (empleado.Estado)
                                {
                                    case ProyectoSegundoParcial.Models.EstadoEmpleado.Activo:
                                        <span class="badge bg-success">Activo</span>
                                        break;
                                    case ProyectoSegundoParcial.Models.EstadoEmpleado.Inactivo:
                                        <span class="badge bg-warning">Inactivo</span>
                                        break;
                                    case ProyectoSegundoParcial.Models.EstadoEmpleado.LicenciaSinPago:
                                        <span class="badge bg-secondary">Licencia</span>
                                        break;
                                    case ProyectoSegundoParcial.Models.EstadoEmpleado.Despedido:
                                        <span class="badge bg-danger">Despedido</span>
                                        break;
                                }
                            </td>
                            <td class="text-center">
                                <a asp-page="Details" asp-route-id="@empleado.Id" class="btn btn-sm btn-info" title="Ver">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-page="Edit" asp-route-id="@empleado.Id" class="btn btn-sm btn-warning" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-page="Delete" asp-route-id="@empleado.Id" class="btn btn-sm btn-danger" title="Eliminar">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .table-hover tbody tr {
        transition: background-color 0.2s ease;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.05);
    }
</style>
