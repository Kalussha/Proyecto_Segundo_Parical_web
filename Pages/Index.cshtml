@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard - Capital Humano";
}

<div class="container-fluid py-5">
    <!-- Header Section -->
    <div class="mb-5">
        <h1 class="display-4 fw-bold text-primary mb-2">
            <i class="fas fa-chart-line me-3"></i>Dashboard
        </h1>
        <p class="lead text-muted">Bienvenido al Sistema de Gestión de Capital Humano</p>
    </div>

    <!-- KPI Cards -->
    <div class="row mb-5">
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card kpi-card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-2 fw-bold">TOTAL EMPLEADOS</p>
                            <h2 class="mb-0 text-primary fw-bold">@Model.TotalEmpleados</h2>
                        </div>
                        <div class="kpi-icon bg-primary bg-opacity-10 p-3 rounded-circle">
                            <i class="fas fa-users fa-2x text-primary"></i>
                        </div>
                    </div>
                    <small class="text-muted"><i class="fas fa-arrow-up me-1 text-success"></i>Activos en el sistema</small>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card kpi-card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-2 fw-bold">DEPARTAMENTOS</p>
                            <h2 class="mb-0 text-success fw-bold">@Model.TotalDepartamentos</h2>
                        </div>
                        <div class="kpi-icon bg-success bg-opacity-10 p-3 rounded-circle">
                            <i class="fas fa-building fa-2x text-success"></i>
                        </div>
                    </div>
                    <small class="text-muted"><i class="fas fa-info-circle me-1"></i>En la organización</small>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card kpi-card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-2 fw-bold">CONSULTAS PENDIENTES</p>
                            <h2 class="mb-0 text-warning fw-bold">@Model.ConsultasPendientes</h2>
                        </div>
                        <div class="kpi-icon bg-warning bg-opacity-10 p-3 rounded-circle">
                            <i class="fas fa-hourglass-end fa-2x text-warning"></i>
                        </div>
                    </div>
                    <small class="text-muted"><i class="fas fa-clock me-1"></i>Por resolver</small>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card kpi-card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-2 fw-bold">TOTAL CONSULTAS</p>
                            <h2 class="mb-0 text-info fw-bold">@Model.ConsultasRecientes.Count</h2>
                        </div>
                        <div class="kpi-icon bg-info bg-opacity-10 p-3 rounded-circle">
                            <i class="fas fa-comments fa-2x text-info"></i>
                        </div>
                    </div>
                    <small class="text-muted"><i class="fas fa-list me-1"></i>Registradas</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mb-5">
        <div class="col-12">
            <h5 class="fw-bold mb-3"><i class="fas fa-lightning-bolt me-2 text-warning"></i>Acciones Rápidas</h5>
            <div class="row">
                <div class="col-md-3 mb-3">
                    <a asp-page="/Empleados/Create" class="btn btn-primary btn-lg w-100 shadow-sm quick-action">
                        <i class="fas fa-user-plus me-2"></i>Crear Empleado
                    </a>
                </div>
                <div class="col-md-3 mb-3">
                    <a asp-page="/Departamentos/Create" class="btn btn-success btn-lg w-100 shadow-sm quick-action">
                        <i class="fas fa-plus me-2"></i>Crear Departamento
                    </a>
                </div>
                <div class="col-md-3 mb-3">
                    <a asp-page="/Consultas/Create" class="btn btn-info btn-lg w-100 shadow-sm quick-action">
                        <i class="fas fa-comment-circle-plus me-2"></i>Nueva Consulta
                    </a>
                </div>
                <div class="col-md-3 mb-3">
                    <a asp-page="/Empleados/Index" class="btn btn-warning btn-lg w-100 shadow-sm quick-action">
                        <i class="fas fa-list me-2"></i>Ver Empleados
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Data Tables -->
    <div class="row">
        <!-- Recent Employees -->
        <div class="col-lg-8 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white py-3">
                    <h6 class="mb-0"><i class="fas fa-users me-2"></i>Empleados Recientes</h6>
                </div>
                <div class="card-body p-0">
                    @if (Model.Empleados.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <tbody>
                                    @foreach (var empleado in Model.Empleados.Take(5))
                                    {
                                        <tr class="align-middle">
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar avatar-md me-2">
                                                        <i class="fas fa-user-circle fa-2x text-primary opacity-50"></i>
                                                    </div>
                                                    <div>
                                                        <strong>@empleado.Nombre @empleado.Apellido</strong>
                                                        <br />
                                                        <small class="text-muted">@empleado.Cargo</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge bg-info">@empleado.Departamento?.Nombre</span>
                                            </td>
                                            <td class="text-end">
                                                <a asp-page="/Empleados/Details" asp-route-id="@empleado.Id" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4 mb-0">No hay empleados registrados</p>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Consultations -->
        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-info text-white py-3">
                    <h6 class="mb-0"><i class="fas fa-comments me-2"></i>Consultas Recientes</h6>
                </div>
                <div class="card-body">
                    @if (Model.ConsultasRecientes.Count > 0)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var consulta in Model.ConsultasRecientes)
                            {
                                <div class="list-group-item ps-0 py-2 border-0">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <h6 class="mb-1">@consulta.Asunto</h6>
                                            <small class="text-muted">@consulta.Empleado?.Nombre</small>
                                        </div>
                                        @switch (consulta.Estado)
                                        {
                                            case ProyectoSegundoParcial.Models.EstadoConsulta.Pendiente:
                                                <span class="badge bg-warning">Pendiente</span>
                                                break;
                                            case ProyectoSegundoParcial.Models.EstadoConsulta.EnProceso:
                                                <span class="badge bg-primary">En Proceso</span>
                                                break;
                                            case ProyectoSegundoParcial.Models.EstadoConsulta.Resuelta:
                                                <span class="badge bg-success">Resuelta</span>
                                                break;
                                            case ProyectoSegundoParcial.Models.EstadoConsulta.Cerrada:
                                                <span class="badge bg-secondary">Cerrada</span>
                                                break;
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4 mb-0">No hay consultas registradas</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* KPI Cards Animation */
    .kpi-card {
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .kpi-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: left 0.5s ease;
    }

    .kpi-card:hover::before {
        left: 100%;
    }

    .kpi-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.15) !important;
    }

    .kpi-icon {
        animation: float 3s ease-in-out infinite;
    }

    /* Quick Action Buttons */
    .quick-action {
        transition: all 0.3s ease;
        font-weight: 600;
    }

    .quick-action:hover {
        transform: translateY(-3px);
        box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.2) !important;
    }

    /* Table Animation */
    .table tbody tr {
        transition: background-color 0.2s ease;
    }

    .table tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.05);
    }
</style>
