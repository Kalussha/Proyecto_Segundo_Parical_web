@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard - Capital Humano";
}

<div class="container-fluid py-5">
    <!-- Header Section -->
    <div class="mb-5">
        <h1 class="display-4 fw-bold text-primary mb-2">
            <i class="fas fa-chart-line me-3"></i>Dashboard
        </h1>
        <p class="lead text-muted">Bienvenido al Sistema de Gestión de Capital Humano</p>
    </div>

    <!-- KPI Cards -->
    <div class="row mb-5">
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card kpi-card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-2 fw-bold">TOTAL EMPLEADOS</p>
                            <h2 class="mb-0 text-primary fw-bold">@Model.TotalEmpleados</h2>
                        </div>
                        <div class="kpi-icon bg-primary bg-opacity-10 p-3 rounded-circle">
                            <i class="fas fa-users fa-2x text-primary"></i>
                        </div>
                    </div>
                    <small class="text-muted"><i class="fas fa-arrow-up me-1 text-success"></i>Activos en el sistema</small>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card kpi-card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-2 fw-bold">DEPARTAMENTOS</p>
                            <h2 class="mb-0 text-success fw-bold">@Model.TotalDepartamentos</h2>
                        </div>
                        <div class="kpi-icon bg-success bg-opacity-10 p-3 rounded-circle">
                            <i class="fas fa-building fa-2x text-success"></i>
                        </div>
                    </div>
                    <small class="text-muted"><i class="fas fa-info-circle me-1"></i>En la organización</small>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card kpi-card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-2 fw-bold">CONSULTAS PENDIENTES</p>
                            <h2 class="mb-0 text-warning fw-bold">@Model.ConsultasPendientes</h2>
                        </div>
                        <div class="kpi-icon bg-warning bg-opacity-10 p-3 rounded-circle">
                            <i class="fas fa-hourglass-end fa-2x text-warning"></i>
                        </div>
                    </div>
                    <small class="text-muted"><i class="fas fa-clock me-1"></i>Por resolver</small>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card kpi-card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-2 fw-bold">TOTAL CONSULTAS</p>
                            <h2 class="mb-0 text-info fw-bold">@Model.ConsultasRecientes.Count</h2>
                        </div>
                        <div class="kpi-icon bg-info bg-opacity-10 p-3 rounded-circle">
                            <i class="fas fa-comments fa-2x text-info"></i>
                        </div>
                    </div>
                    <small class="text-muted"><i class="fas fa-list me-1"></i>Registradas</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mb-5">
        <div class="col-12">
            <h5 class="fw-bold mb-3"><i class="fas fa-lightning-bolt me-2 text-warning"></i>Acciones Rápidas</h5>
            <div class="row">
                <div class="col-md-3 mb-3">
                    <a asp-page="/Empleados/Create" class="neon-button d-flex flex-column align-items-center justify-content-center text-center shadow-sm w-100 h-100 text-decoration-none">
                        <i class="fas fa-user-plus fa-2x mb-2 mt-2"></i><span>Crear Empleado</span>
                    </a>
                </div>
                <div class="col-md-3 mb-3">
                    <a asp-page="/Departamentos/Create" class="neon-button d-flex flex-column align-items-center justify-content-center text-center shadow-sm w-100 h-100 text-decoration-none">
                        <i class="fas fa-plus fa-2x mb-2 mt-2"></i><span>Crear Depto</span>
                    </a>
                </div>
                <div class="col-md-3 mb-3">
                    <a asp-page="/Consultas/Create" class="neon-button d-flex flex-column align-items-center justify-content-center text-center shadow-sm w-100 h-100 text-decoration-none">
                        <i class="fas fa-comment-circle-plus fa-2x mb-2 mt-2"></i><span>Nueva Consulta</span>
                    </a>
                </div>
                <div class="col-md-3 mb-3">
                    <a asp-page="/Empleados/Index" class="neon-button d-flex flex-column align-items-center justify-content-center text-center shadow-sm w-100 h-100 text-decoration-none">
                        <i class="fas fa-list fa-2x mb-2 mt-2"></i><span>Ver Empleados</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Data Tables -->
    <div class="row">
        <!-- Recent Employees -->
        <div class="col-lg-8 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white py-3">
                    <h6 class="mb-0"><i class="fas fa-users me-2"></i>Empleados Recientes</h6>
                </div>
                <div class="card-body p-0">
                    @if (Model.Empleados.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <tbody>
                                    @foreach (var empleado in Model.Empleados.Take(5))
                                    {
                                        <tr class="align-middle">
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar avatar-md me-2">
                                                        <i class="fas fa-user-circle fa-2x text-primary opacity-50"></i>
                                                    </div>
                                                    <div>
                                                        <strong>@empleado.Nombre @empleado.Apellido</strong>
                                                        <br />
                                                        <small class="text-muted">@empleado.Cargo</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge bg-info">@empleado.Departamento?.Nombre</span>
                                            </td>
                                            <td class="text-end">
                                                <a asp-page="/Empleados/Details" asp-route-id="@empleado.Id" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4 mb-0">No hay empleados registrados</p>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Consultations -->
        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-info text-white py-3">
                    <h6 class="mb-0"><i class="fas fa-comments me-2"></i>Consultas Recientes</h6>
                </div>
                <div class="card-body">
                    @if (Model.ConsultasRecientes.Count > 0)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var consulta in Model.ConsultasRecientes)
                            {
                                <div class="list-group-item ps-0 py-2 border-0">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <h6 class="mb-1">@consulta.Asunto</h6>
                                            <small class="text-muted">@consulta.Empleado?.Nombre</small>
                                        </div>
                                        @switch (consulta.Estado)
                                        {
                                            case ProyectoSegundoParcial.Models.EstadoConsulta.Pendiente:
                                                <span class="badge bg-warning">Pendiente</span>
                                                break;
                                            case ProyectoSegundoParcial.Models.EstadoConsulta.EnProceso:
                                                <span class="badge bg-primary">En Proceso</span>
                                                break;
                                            case ProyectoSegundoParcial.Models.EstadoConsulta.Resuelta:
                                                <span class="badge bg-success">Resuelta</span>
                                                break;
                                            case ProyectoSegundoParcial.Models.EstadoConsulta.Cerrada:
                                                <span class="badge bg-secondary">Cerrada</span>
                                                break;
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4 mb-0">No hay consultas registradas</p>
                    }
                </div>
            </div>
        </div>
    <!-- Integración con API (Frontend) -->
    <div class="row mt-5">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-secondary text-white py-3">
                    <h6 class="mb-0"><i class="fas fa-network-wired me-2"></i>Cargado desde la API (Integración Frontend)</h6>
                </div>
                <div class="card-body">
                    <button id="btnCargarApi" class="btn btn-outline-secondary mb-3">
                        <i class="fas fa-sync-alt me-2"></i>Cargar Empleados vía API
                    </button>
                    <ul id="listaEmpleadosApi" class="list-group">
                        <li class="list-group-item text-muted">Haz clic en el botón para cargar los datos usando fetch() hacia la API</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* From Uiverse.io */
    .neon-button {
      position: relative;
      padding: 0.75em 1.5em;
      border-radius: 0.625em;
      border: 2px solid #00ffff;
      font-size: 0.938em;
      text-transform: uppercase;
      font-weight: 700;
      letter-spacing: 0.125em;
      background: transparent;
      color: #00ffff;
      overflow: hidden;
      cursor: pointer;
      box-shadow: 0 0 0 0 transparent;
      transition: all 0.3s ease-in-out;
    }

    .neon-button:hover {
      background: rgba(0, 255, 255, 0.1);
      box-shadow: 0 0 40px 10px rgba(0, 255, 255, 0.5);
      color: #ffffff;
    }

    .neon-button::before {
      content: "";
      display: block;
      width: 0px;
      height: 86%;
      position: absolute;
      top: 7%;
      left: 0%;
      opacity: 0;
      background: linear-gradient(90deg, transparent, #00ffff, transparent);
      box-shadow: 0 0 50px 30px #00ffff;
      transform: skewX(-20deg);
      transition: all 0.5s ease-in-out;
    }

    .neon-button:hover::before {
      animation: neon-shine 0.6s 0s linear;
    }

    @@keyframes neon-shine {
      from {
        opacity: 0;
        left: 0%;
      }

      50% {
        opacity: 1;
      }

      to {
        opacity: 0;
        left: 100%;
      }
    }

    .neon-button:active {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 transparent;
      transition: all 0.2s ease-in;
    }

    /* KPI Cards Animation */
    .kpi-card {
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .kpi-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: left 0.5s ease;
    }

    .kpi-card:hover::before {
        left: 100%;
    }

    .kpi-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.15) !important;
    }

    .kpi-icon {
        animation: float 3s ease-in-out infinite;
    }

    /* Quick Action Buttons */
    .quick-action {
        transition: all 0.3s ease;
        font-weight: 600;
    }

    .quick-action:hover {
        transform: translateY(-3px);
        box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.2) !important;
    }

    /* Table Animation */
    .table tbody tr {
        transition: background-color 0.2s ease;
    }

    .table tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.05);
    }
</style>

@section Scripts {
    <script>
        document.getElementById('btnCargarApi').addEventListener('click', function () {
            const lista = document.getElementById('listaEmpleadosApi');
            lista.innerHTML = '<li class="list-group-item">Cargando datos...</li>';

            fetch('/api/EmpleadosApi')
                .then(response => response.json())
                .then(data => {
                    lista.innerHTML = '';
                    if(data.length === 0){
                        lista.innerHTML = '<li class="list-group-item text-muted">No hay empleados disponibles en la API</li>';
                        return;
                    }

                    data.forEach(emp => {
                        const li = document.createElement('li');
                        li.className = 'list-group-item d-flex justify-content-between align-items-center';
                        li.innerHTML = `
                            <div>
                                <i class="fas fa-user text-primary me-2"></i>
                                <strong>${emp.nombre} ${emp.apellido}</strong> - <span class="text-muted">${emp.cargo}</span>
                            </div>
                            <span class="badge bg-primary rounded-pill">${emp.email}</span>
                        `;
                        lista.appendChild(li);
                    });
                })
                .catch(error => {
                    console.error('Error al cargar la API:', error);
                    lista.innerHTML = '<li class="list-group-item text-danger">Error al cargar datos desde la API.</li>';
                });
        });
    </script>
}
