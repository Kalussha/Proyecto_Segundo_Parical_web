@page
@model Proyecto_Segundo_Parcial.Pages.Departamentos.CreateModel
@{
    ViewData["Title"] = "Crear Departamento";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-primary text-white py-4">
                    <h2 class="mb-0">
                        <i class="fas fa-plus me-2"></i>Crear Nuevo Departamento
                    </h2>
                </div>

                <div class="card-body p-5">
                    <form method="post" novalidate>
                        <div class="mb-3">
                            <label asp-for="Departamento.Nombre" class="form-label fw-semibold">
                                <i class="fas fa-building me-2 text-primary"></i>Nombre del Departamento
                            </label>
                            <input asp-for="Departamento.Nombre" class="form-control form-control-lg" 
                                placeholder="Ingrese el nombre" required />
                            <span asp-validation-for="Departamento.Nombre" class="invalid-feedback d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Departamento.Descripcion" class="form-label fw-semibold">
                                <i class="fas fa-align-left me-2 text-primary"></i>Descripción
                            </label>
                            <textarea asp-for="Departamento.Descripcion" class="form-control form-control-lg" 
                                rows="4" placeholder="Descripción del departamento..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Departamento.PresupuestoAnual" class="form-label fw-semibold">
                                <i class="fas fa-dollar-sign me-2 text-primary"></i>Presupuesto Anual
                            </label>
                            <input asp-for="Departamento.PresupuestoAnual" type="number" step="0.01" 
                                class="form-control form-control-lg" placeholder="0.00" />
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
                            <a asp-page="Index" class="btn btn-lg btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-lg btn-primary">
                                <i class="fas fa-save me-2"></i>Crear Departamento
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
