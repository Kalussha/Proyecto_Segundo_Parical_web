@page
@model Proyecto_Segundo_Parcial.Pages.Departamentos.IndexModel
@{
    ViewData["Title"] = "Gestión de Departamentos";
}

<div class="container-fluid py-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h2 fw-bold text-primary">
                <i class="fas fa-building me-2"></i>Gestión de Departamentos
            </h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-page="Create" class="btn btn-primary btn-lg shadow-sm">
                <i class="fas fa-plus me-2"></i>Nuevo Departamento
            </a>
        </div>
    </div>

    @if (Model.Departamentos.Count == 0)
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            No hay departamentos registrados.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var depto in Model.Departamentos)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card shadow-sm border-0 h-100 department-card">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">
                                <i class="fas fa-layer-group me-2"></i>@depto.Nombre
                            </h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text text-muted">@depto.Descripcion</p>
                            
                            <div class="mb-3">
                                <small class="d-block text-muted fw-bold">PRESUPUESTO ANUAL</small>
                                <strong class="text-success">$@depto.PresupuestoAnual.ToString("N2")</strong>
                            </div>

                            <div class="mb-3">
                                <small class="d-block text-muted fw-bold">EMPLEADOS</small>
                                <strong>@depto.Empleados.Count</strong>
                            </div>
                        </div>
                        <div class="card-footer bg-light border-top">
                            <div class="d-grid gap-2 d-md-flex">
                                <a asp-page="Details" asp-route-id="@depto.Id" class="btn btn-sm btn-info">
                                    <i class="fas fa-eye"></i> Ver
                                </a>
                                <a asp-page="Edit" asp-route-id="@depto.Id" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i> Editar
                                </a>
                                <a asp-page="Delete" asp-route-id="@depto.Id" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .department-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .department-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.15) !important;
    }

    .card-header {
        background: linear-gradient(135deg, #0d6efd 0%, #0a4ed8 100%);
    }
</style>
